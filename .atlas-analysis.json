  "keyFeatures": [
    "Expressive Expectations: 50+ built-in data quality assertions for columns, tables, and custom SQL",
    "Fluent API for connecting to Pandas, Spark, SQL databases, and cloud object storage",
    "Expectation Suites for grouping and reusing data quality checks",
    "Validation Definitions and Checkpoints for production data pipeline integration",
    "Automated Data Docs: human-readable HTML reports of validation results",
    "Extensible custom Expectations via subclassing",
    "Actions system for Slack/email/custom alerting on validation results",
    "Supports ephemeral, file-based, and cloud Data Context backends"
  ],
  "publicApiSurface": [
